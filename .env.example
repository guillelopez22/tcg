# =============================================================================
# La Grieta — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=lagrieta
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=lagrieta
POSTGRES_PORT=5432
# Full connection string (used by Drizzle and NestJS)
DATABASE_URL=postgresql://lagrieta:change_me_in_production@localhost:5432/lagrieta

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PASSWORD=change_me_in_production
REDIS_PORT=6379
REDIS_URL=redis://:change_me_in_production@localhost:6379

# -----------------------------------------------------------------------------
# NestJS API
# -----------------------------------------------------------------------------
NODE_ENV=development
API_PORT=3001
# Global API prefix — do NOT include trailing slash
API_PREFIX=api

# -----------------------------------------------------------------------------
# JWT Auth
# For production use RS256: set JWT_PRIVATE_KEY and JWT_PUBLIC_KEY instead.
# For early development HS256 is acceptable.
# -----------------------------------------------------------------------------
JWT_SECRET=change_me_at_least_32_chars_long_in_production
JWT_ACCESS_TOKEN_TTL=900        # 15 minutes in seconds
JWT_REFRESH_TOKEN_TTL=2592000   # 30 days in seconds

# RS256 keys (production) — base64-encoded PEM, leave empty for HS256 dev mode
# JWT_PRIVATE_KEY=
# JWT_PUBLIC_KEY=

# -----------------------------------------------------------------------------
# Cloudflare R2 (file uploads)
# -----------------------------------------------------------------------------
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=la-grieta-uploads
# Public URL for R2 bucket (custom domain or r2.dev subdomain)
R2_PUBLIC_URL=https://uploads.lagrieta.app

# -----------------------------------------------------------------------------
# Stripe (Phase 5+)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Platform fee in basis points (e.g. 500 = 5%)
STRIPE_PLATFORM_FEE_BPS=500

# -----------------------------------------------------------------------------
# WhatsApp (Phase 4+)
# -----------------------------------------------------------------------------
# Use either Cloud API or Baileys — uncomment the relevant section

# WhatsApp Cloud API
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_VERIFY_TOKEN=

# Baileys (self-hosted, session-based)
# WHATSAPP_SESSION_DIR=./whatsapp-sessions

# -----------------------------------------------------------------------------
# Next.js Web App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_R2_PUBLIC_URL=https://uploads.lagrieta.app

# -----------------------------------------------------------------------------
# CORS
# Comma-separated list of allowed origins
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:19006

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
THROTTLE_PUBLIC_LIMIT=100
THROTTLE_PUBLIC_TTL=60000       # 1 minute in ms
THROTTLE_AUTH_LIMIT=1000
THROTTLE_AUTH_TTL=60000
THROTTLE_LOGIN_LIMIT=10
THROTTLE_LOGIN_TTL=60000
